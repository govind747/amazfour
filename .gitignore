# ==========================================
# Comprehensive .gitignore
# ==========================================

# --- OS Specific Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Build & Compiled Files ---
*.com
*.class
*.dll
*.exe
*.o
*.so
*.out
*.app
dist/
build/
bin/
obj/

# --- Dependencies & Packages ---
node_modules/
jspm_packages/
.npm
.yarn
bower_components/
vendor/
packages/

# --- Environment & Secret Files (CRITICAL) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.secret
*.private

# --- IDE & Editor Files ---
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.settings/
.buildpath

# --- Logs & Temp ---
*.log
*.tmp
*.temp
/temp/*
/tmp/*

# --- Coverage & Testing ---
coverage/
.nyc_output/
.cache/

# --- OS Specific - Linux/Windows ---
*~
*.bak
*.swp
